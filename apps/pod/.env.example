CLOUDY_API_URL=http://localhost:3001
CLOUDY_SIMULATOR=1
CLOUDY_STATE_DIR=.state
CLOUDY_APPROVE_PIN=5
CLOUDY_REJECT_PIN=6
CLOUDY_BUTTON_HOLD_SECONDS=0.6
# Hardware only; the production service defaults to this INMP441 ALSA card.
# CLOUDY_MIC_DEVICE=plughw:CARD=sndrpii2scard,DEV=0
# SPI framebuffer deployments only:
# CLOUDY_FRAMEBUFFER=auto
# CLOUDY_TOUCH_DEVICE=auto
# CLOUDY_TOUCH_SWAP_XY=1
# CLOUDY_TOUCH_INVERT_X=1
# CLOUDY_TOUCH_INVERT_Y=1
# CLOUDY_BUTTONS=0
# CLOUDY_BACKLIGHT=auto
GPIOZERO_PIN_FACTORY=mock
