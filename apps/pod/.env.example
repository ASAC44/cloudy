# API and local state
PODEX_API_URL=http://localhost:3001
PODEX_SIMULATOR=1
PODEX_STATE_DIR=apps/pod/.state

# Physical controls (BCM GPIO pin numbers)
PODEX_APPROVE_PIN=5
PODEX_REJECT_PIN=6

# Display behavior
PODEX_IDLE_ANIMATION_SECONDS=30
PODEX_REDUCED_MOTION=0

# Optional scripted simulator content: github-pr or email-chat
PODEX_DEMO=

# Local simulator GPIO backend; omit on Raspberry Pi hardware
GPIOZERO_PIN_FACTORY=mock
