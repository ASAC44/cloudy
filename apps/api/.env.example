# Core database and credential encryption (required)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your_server_only_key
CONNECTION_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Public application origins (required)
PODEX_PUBLIC_API_URL=http://localhost:3001
PODEX_WEB_URL=http://localhost:3000

# Development-only SQLite fallback for Pod layouts and Google Calendar OAuth testing
PODEX_LOCAL_LAYOUT_DB=.state/podex.sqlite

# Provider OAuth (required only for the corresponding connection)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Telegram personal-account mode only; bot-token mode does not use these
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=

# Stable unique ID per worker process/replica
PODEX_WORKER_ID=local-worker-1

# Railway injects PORT in production; local API defaults to 3001
# PORT=3001
