# Core database and credential encryption (required)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your_server_only_key
CONNECTION_ENCRYPTION_KEY=replace-with-32-byte-base64-key
CLOUDY_PUBLIC_API_URL=http://localhost:3001
CLOUDY_WEB_URL=http://localhost:3000
# Development only; scripts/dev.sh sets this to an absolute SQLite path automatically.
CLOUDY_LOCAL_LAYOUT_DB=
# Provider OAuth (required only for the corresponding connection)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
CLOUDY_WORKER_ID=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Graph memory (set URL and secret together on the worker; timeout is optional)
MEMORY_SERVICE_URL=
MEMORY_INTERNAL_SECRET=
MEMORY_REQUEST_TIMEOUT_MS=10000
MEMORY_LEARNED_ACTIONS_ENABLED=true
# Start new deployments closed; advance these only after the documented checks.
MEMORY_LEARNED_ACTIONS_ROLLOUT_PERCENT=0
MEMORY_HISTORY_IMPORTS_ENABLED=false

# Telegram personal-account mode only; bot-token mode does not use these
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=

# Stable unique ID per worker process/replica
CLOUDY_WORKER_ID=local-worker-1

# Railway injects PORT in production; local API defaults to 3001
# PORT=3001
