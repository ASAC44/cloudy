{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx --watch src/index.ts",
    "dev:worker": "node --env-file-if-exists=.env --import tsx --watch src/worker.ts",
    "build": "tsc",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "start:worker": "node --env-file-if-exists=.env dist/worker.js",
    "test": "tsx --test src/*.test.ts",
    "test:memory-release": "tsx --test src/memory-release.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.16",
    "@ai-sdk/cerebras": "^3.0.12",
    "@ai-sdk/openai": "^4.0.16",
    "@ai-sdk/openai-compatible": "^3.0.12",
    "@hono/node-server": "^2.0.10",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@supabase/supabase-js": "^2.110.7",
    "ai": "^7.0.31",
    "hono": "^4.12.31",
    "qrcode": "^1.5.4",
    "telegram": "^2.26.22",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
